# ─────────────────────────────────────────────────────────────────────
# ملف متغيرات البيئة — انسخه إلى .env وعدّل القيم
# ⚠️  لا تُرفق ملف .env أبداً في مستودع الكود (مُستبعد في .gitignore)
# ─────────────────────────────────────────────────────────────────────

# الأمان (إلزامي للإنتاج)
DJANGO_DEBUG=false
DJANGO_SECRET_KEY=replace-with-a-long-random-string-at-least-50-chars
DJANGO_SECURE_SSL_REDIRECT=false

# قاعدة البيانات (اترك الافتراضي لـ SQLite، عدّل لـ PostgreSQL في الإنتاج)
DJANGO_DB_ENGINE=sqlite
DJANGO_DB_NAME=accounting
DJANGO_DB_USER=accounting
DJANGO_DB_PASSWORD=change-me-strong
DJANGO_DB_HOST=127.0.0.1
DJANGO_DB_PORT=5432

# الشبكة
BIND_PORT=8012
HOST_IP=192.168.1.31
EXTERNAL_IP=196.218.24.45

# Gunicorn
GUNICORN_WORKERS=2

# Celery (اترك True للوضع المتزامن بدون Redis)
DJANGO_CELERY_EAGER=true

# Cache (اترك بدون تحديد لـ LocMemCache، عدّل لـ Redis في الإنتاج)
# DJANGO_CACHE_BACKEND=redis
# DJANGO_CACHE_URL=redis://127.0.0.1:6379/2
